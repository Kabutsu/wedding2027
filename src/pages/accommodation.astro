---

<Layout>
  <PageHeader title="Accommodation" />

  <section
    id="content"
    class="flex flex-col items-center justify-start gap-12 p-6 sm:gap-16 sm:p-12 sm:px-82 w-full"
  >
    <!-- Intro paragraph -->
    <div
      class="flex flex-col items-start justify-start gap-4 max-w-5xl font-(family-name:--font-cormorant) text-wedding-dark"
    >
      <p class="intro-para">
        We've compiled a list of wonderful accommodation options nearby, ranging
        from boutique hotels and charming inns to cosy cottages and bed &
        breakfasts. Whether you'd like to be close to the barn or prefer a
        scenic drive, you'll find something that suits you.
      </p>
    </div>

    <!-- Hotels & Inns Table -->
    <div class="w-full max-w-5xl">
      <h2 class="table-heading">Hotels & Inns</h2>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Accommodation</th>
              <th class="hidden sm:table-cell">Location</th>
              <th>Phone</th>
              <th>Website</th>
              <th>Distance</th>
            </tr>
          </thead>
          <tbody>
            {
              hotelsAndInns.map((item, index) => (
                <tr class={index % 2 === 0 ? "even-row" : ""}>
                  <td class="name-cell">{item.name}</td>
                  <td class="hidden sm:table-cell">{item.postcode}</td>
                  <td class="phone-cell">{item.phone}</td>
                  <td class="link-cell">
                    <a
                      href={`https://${item.website.replace(/^https?:\/\//, "")}`}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Visit
                    </a>
                  </td>
                  <td class="distance-cell">{item.distance} mins</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Cottages, Apartments & Longer Lets Table -->
    <div class="w-full max-w-5xl">
      <h2 class="table-heading">Cottages, Apartments & Longer Lets</h2>
      <div class="table-wrapper">
        <table class="data-table">
