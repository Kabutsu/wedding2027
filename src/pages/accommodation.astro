</Layout>

<style>
  #content {
    max-width: 100%;
  }

  .intro-para {
    font-weight: 600;
    font-size: larger;
    text-wrap: pretty;
  }

  .table-heading {
    font-family: var(--font-boston);
    font-size: 2rem;
    color: var(--color-crimson);
    margin-bottom: 1rem;
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: 0.5rem;
    box-shadow: var(--drop-shadow-wedding);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background-color: white;
  }

  .data-table thead {
    background-color: var(--color-crimson);
    color: var(--color-ivory);
  }

  .data-table th {
    padding: 1rem;
    text-align: left;
    font-weight: lighter;
    font-size: 1.25rem;
    font-family: var(--font-boston);
  }

  .data-table td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.95rem;
  }

  .data-table tbody tr {
    transition: background-color 0.2s ease;
  }

  .data-table tbody tr:hover {
    background-color: #faf8f5;
  }

  .data-table tbody tr.even-row {
    background-color: #fdfbf8;
  }

  .data-table tbody tr.even-row:hover {
    background-color: #faf8f5;
  }

  .name-cell {
    font-weight: 600;
    color: var(--color-wedding-dark);
  }

  .phone-cell {
    font-family: monospace;
    font-size: 0.9rem;
  }

  .link-cell a {
    color: var(--color-wedding-burgundy);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .link-cell a:hover {
    color: var(--color-crimson);
    text-decoration: underline;
  }

  .distance-cell {
    text-align: center;
    font-weight: 500;
    color: #666;
  }

  @media (max-width: 768px) {
    .data-table th,
    .data-table td {
      padding: 0.75rem 0.5rem;
      font-size: 0.875rem;
    }

    .table-heading {
      font-size: 1.35rem;
    }
  }
</style>
