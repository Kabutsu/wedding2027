---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <PageHeader title="Dress Code" />

  <section
    id="content"
    class="flex flex-col items-center justify-start gap-8 p-6 sm:gap-12 sm:p-12 sm:px-82"
  >
    <div
      class="flex flex-col items-start justify-start gap-4 sm:gap-6 max-w-5xl font-(family-name:--font-cormorant) text-wedding-dark"
    >
      <p>We're planning a relaxed and joyful winter celebration.</p>
      <p>
        We encourage guests to dress up, embrace colour, and have fun with
        texture and personality. Think rich winter tones, romantic florals,
        velvet, silk, satin, embroidery, or statement accessories. Suits,
        dresses, jumpsuits, separates, and creative interpretations are all
        welcome.
      </p>
      <p>
        Most importantly, wear something that makes you feel wonderful and ready
        to celebrate.
      </p>
    </div>

    <div id="pinterest-container" style="width: 100%; max-width: 800px; margin: 0 auto;">
      <a
        id="pinterest-embed"
        data-pin-do="embedBoard"
        href="https://www.pinterest.com/carolinaj215/romantic-winter-cocktail/?invite_code=c9a2b98c7a6e4e63887226ac9a4b48f0&sender=224898712550285143"
      >
      </a>
      <!-- Fallback for iOS/mobile devices where embed doesn't work -->
      <div id="pinterest-fallback" style="display: none; text-align: center; padding: 2rem; background: #f5f1ed; border-radius: 8px; margin-top: 1rem;">
        <p style="margin: 0 0 1rem 0; font-weight: 600;">View our inspiration board on Pinterest</p>
        <a
          href="https://www.pinterest.com/carolinaj215/romantic-winter-cocktail/?invite_code=c9a2b98c7a6e4e63887226ac9a4b48f0&sender=224898712550285143"
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-block; padding: 0.75rem 1.5rem; background: var(--color-wedding-burgundy); color: white; text-decoration: none; border-radius: 4px; font-weight: 600; transition: background 0.2s ease;"
        >
          View Board →
        </a>
      </div>
    </div>

    <script is:inline type="text/javascript">
      async function requestStorageAccessAndRetry() {
        try {
          if (document.requestStorageAccess) {
            await document.requestStorageAccess();
            // Access granted, reload to activate with cookies
            window.location.reload();
          }
        } catch (e) {
          console.log('Storage access denied or unavailable');
        }
      }

      function initPinterestEmbed() {
        const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);

        if (window.PinUtils && window.PinUtils.build) {
          if (isIOS) {
            // On iOS, show fallback by default (ITP blocks the embed)
            const embed = document.getElementById('pinterest-embed');
            const fallback = document.getElementById('pinterest-fallback');
            if (embed && fallback) {
              embed.style.display = 'none';
              fallback.style.display = 'block';
              // Update fallback button to try requesting storage access
              const btn = fallback.querySelector('a');
              if (btn && document.requestStorageAccess) {
                btn.textContent = 'Enable & View Board →';
                btn.onclick = (e) => {
                  e.preventDefault();
                  requestStorageAccessAndRetry();
                };
              }
            }
          } else {
            window.PinUtils.build();
          }
          return;
        }

        // Load Pinterest embed script
        const script = document.createElement('script');
        script.src = 'https://assets.pinterest.com/js/pinit.js';
        script.async = true;
        script.onload = function() {
          if (isIOS) {
            // Still show fallback on iOS due to ITP
            const embed = document.getElementById('pinterest-embed');
            const fallback = document.getElementById('pinterest-fallback');
            if (embed && fallback) {
              embed.style.display = 'none';
              fallback.style.display = 'block';
              const btn = fallback.querySelector('a');
              if (btn && document.requestStorageAccess) {
                btn.textContent = 'Enable & View Board →';
                btn.onclick = (e) => {
                  e.preventDefault();
                  requestStorageAccessAndRetry();
                };
              }
            }
          } else if (window.PinUtils && window.PinUtils.build) {
            setTimeout(() => {
              window.PinUtils.build();
            }, 100);
          }
        };
        script.onerror = function() {
          const embed = document.getElementById('pinterest-embed');
          const fallback = document.getElementById('pinterest-fallback');
          if (embed && fallback) {
            embed.style.display = 'none';
            fallback.style.display = 'block';
          }
        };
        document.body.appendChild(script);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPinterestEmbed);
      } else {
        setTimeout(initPinterestEmbed, 100);
      }

      window.addEventListener('load', function() {
        const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);
        if (!isIOS && window.PinUtils && window.PinUtils.build) {
          window.PinUtils.build();
        }
      });
    </script>
  </section>

  <Footer />
</Layout>

<style>
  #content p {
    text-wrap: pretty;
    font-weight: 600;
    font-size: larger;
  }
</style>
