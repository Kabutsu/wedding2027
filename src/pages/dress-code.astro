---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <PageHeader title="Dress Code" />

  <section
    id="content"
    class="flex flex-col items-center justify-start gap-8 p-6 sm:gap-12 sm:p-12 sm:px-82"
  >
    <div
      class="flex flex-col items-start justify-start gap-4 sm:gap-6 max-w-5xl font-(family-name:--font-cormorant) text-wedding-dark"
    >
      <p>We're planning a relaxed and joyful winter celebration.</p>
      <p>
        We encourage guests to dress up, embrace colour, and have fun with
        texture and personality. Think rich winter tones, romantic florals,
        velvet, silk, satin, embroidery, or statement accessories. Suits,
        dresses, jumpsuits, separates, and creative interpretations are all
        welcome.
      </p>
      <p>
        Most importantly, wear something that makes you feel wonderful and ready
        to celebrate.
      </p>
    </div>

    <div id="pinterest-container" style="width: 100%; max-width: 600px; margin: 0 auto;">
      <a
        id="pinterest-embed"
        data-pin-do="embedBoard"
        href="https://www.pinterest.com/carolinaj215/romantic-winter-cocktail/?invite_code=c9a2b98c7a6e4e63887226ac9a4b48f0&sender=224898712550285143"
      >
      </a>
    </div>

    <script is:inline type="text/javascript">
      function initPinterestEmbed() {
        // If Pinterest script is already loaded, reprocess the embeds
        if (window.PinUtils && window.PinUtils.build) {
          window.PinUtils.build();
          return;
        }

        // Load the Pinterest embed script
        const script = document.createElement('script');
        script.src = 'https://assets.pinterest.com/js/pinit.js';
        script.async = true;
        script.onload = function() {
          // Ensure the embed is processed after script loads
          if (window.PinUtils && window.PinUtils.build) {
            setTimeout(() => {
              window.PinUtils.build();
            }, 100);
          }
        };
        script.onerror = function() {
          console.warn('Failed to load Pinterest embed script');
        };
        document.body.appendChild(script);
      }

      // Wait for DOM to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPinterestEmbed);
      } else {
        // Small delay to ensure layout is complete
        setTimeout(initPinterestEmbed, 100);
      }

      // Also try to reinitialize on load
      window.addEventListener('load', function() {
        if (window.PinUtils && window.PinUtils.build) {
          window.PinUtils.build();
        }
      });
    </script>
  </section>

  <Footer />
</Layout>

<style>
  #content p {
    text-wrap: pretty;
    font-weight: 600;
    font-size: larger;
  }
</style>
