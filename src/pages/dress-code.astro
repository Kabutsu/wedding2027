---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <svg width="0" height="0">
    <defs>
      <clipPath id="wave-clip" clipPathUnits="objectBoundingBox">
        <path d="M 0,0 L 0,0.85 Q 0.5,1 1,0.85 L 1,0 Z"></path>
      </clipPath>
    </defs>
  </svg>

  <section id="header" class="relative w-full">
    <div
      id="header-content"
      class="w-full h-full py-8 sm:py-16 flex flex-col items-center justify-start gap-2.5 bg-crimson"
    >
      <h1
        class="text-4xl sm:text-6xl font-(family-name:--font-boston) text-ivory"
      >
        Dress Code
      </h1>
    </div>
  </section>

  <section
    id="content"
    class="flex flex-col items-center justify-start gap-8 p-6 sm:gap-12 sm:p-12 sm:px-82"
  >
    <div
      class="flex flex-col items-start justify-start gap-4 sm:gap-6 max-w-5xl font-(family-name:--font-cormorant) text-wedding-dark"
    >
      <p>We're planning a relaxed and joyful winter celebration.</p>
      <p>
        We encourage guests to dress up, embrace colour, and have fun with
        texture and personality. Think rich winter tones, romantic florals,
        velvet, silk, satin, embroidery, or statement accessories. Suits,
        dresses, jumpsuits, separates, and creative interpretations are all
        welcome.
      </p>
      <p>
        Most importantly, wear something that makes you feel wonderful and ready
        to celebrate.
      </p>
    </div>

    <a
      data-pin-do="embedBoard"
      href="https://www.pinterest.com/carolinaj215/romantic-winter-cocktail/?invite_code=c9a2b98c7a6e4e63887226ac9a4b48f0&sender=224898712550285143"
      data-pin-scale-width="120"
      data-pin-scale-height="600"
      data-pin-board-width="600"
    >
    </a>
    <script
      is:inline
      async
      defer
      type="text/javascript"
      src="https://assets.pinterest.com/js/pinit.js"></script>
  </section>

  <Footer />
</Layout>

<style>
  #header {
    clip-path: url(#wave-clip);
    overflow: hidden;
  }

  #content p {
    text-wrap: pretty;
    font-weight: 600;
    font-size: large;
  }
</style>
