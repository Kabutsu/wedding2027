---
import { Image } from "astro:assets";
import { PUBLIC_RSVP_LINK } from "astro:env/client";

import footerImg from "@/assets/images/wedding-logo.png";

const asPath = Astro.url.pathname;
---

<footer class="relative w-full overflow-visible">
  <div class="relative w-full h-8">
    <Image
      src={footerImg}
      alt="Footer image"
      class="absolute top-8 left-1/2 -translate-x-1/2 -translate-y-1/4 w-32 h-32 object-cover object-top rounded-full z-10"
    />
  </div>
  <div id="footer-content-container" class="w-full min-h-[50svh]">
    <div
      id="footer-content"
      class="w-full h-full px-4 pt-32 pb-10 bg-wedding-dark flex flex-col items-center justify-start gap-2.5"
    >
      <h2
        class="text-center text-white text-4xl font-(family-name:--font-cormorant) font-bold pb-4"
      >
        Sam & Carolina
      </h2>
      {asPath === "/" ? null : <a href="/">Home</a>}
      <a href={PUBLIC_RSVP_LINK} target="_blank" rel="noopener noreferrer">
        RSVP
      </a>
      {asPath === "/dress-code" ? null : <a href="/dress-code">Dress Code</a>}
      {
        asPath === "/accommodation" ? null : (
          <a href="/accommodation">Accommodation</a>
        )
      }
      {asPath === "/transport" ? null : <a href="/transport">Transport</a>}
    </div>
  </div>
</footer>

<style>
  #footer-content-container {
    clip-path: url(#wave-clip-footer-mobile);
  }

  #footer-content-container a {
    display: block;
    text-align: center;
    color: #fff;
    font-size: 1.125rem;
    transition:
      color 0.3s ease,
      font-size 0.3s ease;
  }

  #footer-content-container a:hover {
    color: #f5f1ed;
    font-size: 1.2rem;
  }

  @media (min-width: 768px) {
    #footer-content-container {
      clip-path: url(#wave-clip-footer);
    }
  }
</style>

<svg width="0" height="0">
  <defs>
    <clipPath id="wave-clip-footer" clipPathUnits="objectBoundingBox">
      <path
        d="M 1,1 L 1,0.05 C 0.75,0.05 0.75,0 0.5,0 C 0.25,0 0.25,0.05 0,0.05 L 0,1 Z"
      ></path>
    </clipPath>
    <clipPath id="wave-clip-footer-mobile" clipPathUnits="objectBoundingBox">
      <path d="M 1,1 L 1,0.02 Q 0.5,0 0,0.02 L 0,1 Z"></path>
    </clipPath>
  </defs>
</svg>
