---
import { Image } from "astro:assets";
import { PUBLIC_RSVP_LINK } from "astro:env/client";

import footerImg from "@/assets/images/disney-1.jpg";
---

<footer class="relative h-[50svh] w-full overflow-visible">
  <div class="relative w-full h-8">
    <Image
      src={footerImg}
      alt="Footer image"
      class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-24 object-cover object-top rounded-full border-dusty-blue border-4"
    />
  </div>
  <div
    id="footer-content"
    class="w-full h-full p-4 pt-24 bg-wedding-dark flex flex-col items-center justify-start gap-2.5"
  >
    <h2
      class="text-center text-white text-4xl font-(family-name:--font-cormorant) font-bold"
    >
      Sam & Carolina
    </h2>
    <a href={PUBLIC_RSVP_LINK} target="_blank">RSVP</a>
  </div>
</footer>

<style>
  a {
    display: block;
    text-align: center;
    color: #fff;
    font-size: 1.125rem;
    transition:
      color 0.3s ease,
      font-size 0.3s ease;
  }

  a:hover {
    color: var(--color-dusty-blue);
    font-size: 1.25rem;
  }
</style>
