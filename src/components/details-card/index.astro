---
import { Image } from "astro:assets";

const { title, description, buttonText, buttonLink, img } = Astro.props;
---

<div
  id="details-card"
  class="relative w-240 h-100 bg-ivory rounded-2xl border-ivory border-4 shadow-lg overflow-hidden grid grid-cols-2 gap-4 mt-6 transition-all duration-500 ease-in-out hover:scale-105 hover:shadow-xl"
>
  <div class="flex flex-col items-start justify-start gap-2 p-8 pt-12 pr-2">
    <h3
      class="text-2xl sm:text-[3.25rem] font-bold font-(family-name:--font-boston) text-dusty-blue"
    >
      {title}
    </h3>
    <p class="text-left text-pretty text-xl pb-12 w-96">{description}</p>
    {
      buttonText && buttonLink && (
        <button
          class="mt-2 px-6 py-2 cursor-pointer bg-dusty-blue text-white font-(family-name:--font-cormorant) rounded-full text-xl font-semibold hover:bg-dark-blue/90 transition-colors duration-300"
          onclick={`window.open("${buttonLink}", "_blank")`}
        >
          {buttonText}
        </button>
      )
    }
  </div>

  <Image
    src={img}
    alt={title}
    class="w-full h-full object-cover object-center rounded-lg"
  />
</div>

<style>
  #details-card-image {
    corner-shape: squircle;
  }
</style>
