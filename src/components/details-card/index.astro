---
import { Image } from "astro:assets";

const { title, description, buttonText, buttonLink, img } = Astro.props;
---

<div
  id="details-card"
  class="relative w-[90svw] h-auto sm:w-240 sm:h-100 bg-ivory rounded-2xl border-ivory border-4 shadow-lg overflow-hidden grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6 transition-all duration-500 ease-in-out hover:scale-105 hover:shadow-xl"
>
  <div
    class="flex flex-col items-center sm:items-start justify-start gap-2 p-2 sm:p-8 pt-4 sm:pt-12 pr-2"
  >
    <h3
      class="text-3xl sm:text-[3.25rem] font-bold font-(family-name:--font-boston) text-dusty-blue"
    >
      {title}
    </h3>
    <p
      class="text-center sm:text-left text-pretty text-base sm:text-xl sm:pb-12 w-full sm:w-96"
    >
      {description}
    </p>
    {
      buttonText && buttonLink && (
        <a
          href={buttonLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 px-6 py-2 cursor-pointer bg-dusty-blue text-white font-(family-name:--font-cormorant) rounded-full text-lg sm:text-xl font-semibold hover:bg-dark-blue/90 transition-colors duration-300"
        >
          {buttonText}
        </a>
      )
    }
  </div>

  <Image
    src={img}
    alt={title}
    class="w-full h-56 sm:h-full object-cover object-center rounded-lg"
  />
</div>

<style>
  #details-card-image {
    corner-shape: squircle;
  }
</style>
