---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

// Lazy load images on-demand instead of eager loading all into initial bundle
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/photoshoot/*.jpg",
);

// Resolve all lazy-loaded image promises
const images = await Promise.all(
  Object.values(imageModules).map(async (module) => (await module()).default),
);
---

<section
  id="slideshow"
  class="flex flex-row h-full max-w-full pt-4 overflow-x-auto overflow-y-hidden"
>
  {
    images.map((image, index) => (
      <div
        id="slideshow-item"
        class="shrink-0 h-full max-h-[90vh] aspect-square sm:aspect-5/4"
      >
        <Image
          src={image}
          alt={`Photo ${index + 1}`}
          class="w-full h-full object-cover"
          style={{ objectPosition: "center center", display: "block" }}
          priority={index === 0}
          format="webp"
          quality="high"
          widths={[600, 1200, 1920]}
          sizes="(max-width: 640px) 600px, (max-width: 1280px) 1200px, 1920px"
        />
      </div>
    ))
  }
</section>

<style>
  #slideshow {
    scroll-snap-type: x mandatory;
  }

  #slideshow-item {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
</style>
