---
// No JavaScript needed for CSS-only parallax
import { getImage } from "astro:assets";
import bannerImg from "../assets/images/proposoal-1.jpg";

// Only process the placeholder through getImage - keep full-res as original URL
const placeholderImage = await getImage({
  src: bannerImg,
  width: 40,
  quality: 40,
});

// Use the original image URL directly for full-res
const fullImageUrl = bannerImg.src;
---

<!-- Preload the full-res image with high priority -->
<link rel="preload" fetchpriority="high" as="image" href={fullImageUrl} />

<!-- Pass image URLs to CSS via custom properties -->
<style
  define:vars={{
    fullImageUrl: `url(${fullImageUrl})`,
    placeholderUrl: `url(${placeholderImage.src})`,
  }}
></style>

<div id="banner-container" class="min-h-[90svh] sm:min-h-[150vh]">
  <div id="banner" class="h-[90svh] sm:h-[150vh]">
    <div id="banner-full"></div>
  </div>
</div>

<style>
  #banner-container {
    width: 100%;
    max-width: 100vw;
    position: relative;
    overflow: clip;
    clip-path: url(#wave-clip-mobile);
  }

  #banner {
    position: relative;
    width: 100%;
    background-color: #f5f1ed;

    /* Scroll-driven animation for smooth parallax */
    animation: parallax-scroll linear;
    animation-timeline: scroll();
    animation-range: entry 0% exit 100%;

    /* Optimize rendering performance */
    will-change: transform;
  }

  /* Placeholder layer - blurred and behind */
  #banner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--placeholderUrl);
    background-size: cover;
    background-position: center -150px;
    background-repeat: no-repeat;
    filter: blur(20px);
    z-index: 1;
  }

  /* Child element for full-res image - sharp and on top */
  #banner-full {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--fullImageUrl);
    background-size: cover;
    background-position: center -150px;
    background-repeat: no-repeat;
    opacity: 0;
    animation: fade-in ease-in-out 0.5s forwards;
    animation-delay: 0.15s;
    z-index: 2;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes parallax-scroll {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(65vh); /* Subtle upward movement */
    }
  }

  @media (min-width: 768px) {
    #banner-container {
      clip-path: url(#wave-clip);
    }
  }
</style>

<svg width="0" height="0">
  <defs>
    <clipPath id="wave-clip" clipPathUnits="objectBoundingBox">
      <path
        d="M 0,0 L 0,0.95 C 0.25,0.95 0.25,1 0.5,1 C 0.75,1 0.75,0.95 1,0.95 L 1,0 Z"
      ></path>
    </clipPath>
    <clipPath id="wave-clip-mobile" clipPathUnits="objectBoundingBox">
      <path d="M 0,0 L 0,0.98 Q 0.5,1 1,0.98 L 1,0 Z"></path>
    </clipPath>
  </defs>
</svg>
